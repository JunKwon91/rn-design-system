{
  "name": "@junkwon91/rn-design-system",
  "version": "2.1.1",
  "private": true,
  "main": "lib/commonjs/index.js",
  "module": "lib/module/index.js",
  "types": "lib/typescript/commonjs/index.d.ts",
  "react-native": "src/index.ts",
  "source": "src/index.ts",
  "files": [
    "src",
    "lib",
    "!**/__tests__",
    "!**/*.test.*",
    "!**/test-utils"
  ],
  "sideEffects": false,
  "repository": {
    "type": "git",
    "url": "https://github.com/JunKwon91/rn-design-system.git"
  },
  "scripts": {
    "android": "react-native run-android",
    "ios": "react-native run-ios",
    "lint": "eslint .",
    "start": "react-native start",
    "test": "jest",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "prepare": "bob build"
  },
  "dependencies": {
    "lucide-react-native": "^1.14.0",
    "zustand": "^5.0.13"
  },
  "peerDependencies": {
    "react": ">=19.0.0",
    "react-native": ">=0.81.0",
    "react-native-gesture-handler": ">=2.0.0",
    "react-native-reanimated": ">=4.0.0",
    "react-native-safe-area-context": ">=5.0.0",
    "react-native-svg": ">=15.0.0",
    "react-native-worklets": ">=0.8.0",
    "styled-components": ">=6.0.0"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@babel/preset-env": "^7.25.3",
    "@babel/runtime": "^7.25.0",
    "@react-native-community/cli": "20.1.0",
    "@react-native-community/cli-platform-android": "20.1.0",
    "@react-native-community/cli-platform-ios": "20.1.0",
    "@react-native/babel-preset": "0.85.3",
    "@react-native/eslint-config": "0.85.3",
    "@react-native/jest-preset": "0.85.3",
    "@react-native/metro-config": "0.85.3",
    "@react-native/typescript-config": "0.85.3",
    "@react-navigation/native": "^7.3.8",
    "@react-navigation/native-stack": "^7.17.10",
    "@testing-library/react-native": "^13.3.3",
    "@types/jest": "^29.5.13",
    "@types/react": "^19.2.0",
    "@types/react-test-renderer": "^19.1.0",
    "@types/styled-components-react-native": "^5.2.5",
    "babel-plugin-module-resolver": "^5.0.3",
    "eslint": "^8.19.0",
    "jest": "^29.6.3",
    "prettier": "2.8.8",
    "react": "19.2.3",
    "react-native": "0.85.3",
    "react-native-builder-bob": "^0.41.0",
    "react-native-edge-to-edge": "^1.8.1",
    "react-native-gesture-handler": "^2.31.2",
    "react-native-reanimated": "^4.3.1",
    "react-native-safe-area-context": "^5.7.0",
    "react-native-screens": "^4.26.0",
    "react-native-svg": "^15.15.4",
    "react-native-worklets": "^0.8.3",
    "react-test-renderer": "19.2.3",
    "styled-components": "^6.4.1",
    "typescript": "^5.8.3"
  },
  "react-native-builder-bob": {
    "source": "src",
    "output": "lib",
    "exclude": "**/{__tests__,__fixtures__,__mocks__,test-utils}/**",
    "targets": [
      [
        "commonjs",
        {
          "esm": true
        }
      ],
      [
        "module",
        {
          "esm": true
        }
      ],
      [
        "typescript",
        {
          "project": "tsconfig.build.json"
        }
      ]
    ]
  },
  "engines": {
    "node": ">= 22.11.0"
  }
}
